{
  "name": "team-memory-mcp",
  "version": "1.0.0",
  "description": "MCP Server for team memory - shared knowledge base for Claude Code agents",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy-static",
    "copy-static": "cpy \"src/web/public/**/*\" dist/web/public/",
    "start": "node dist/index.js",
    "start:web": "node dist/standalone-web.js",
    "dev": "npm run build && node dist/index.js",
    "dev:web": "npm run build && node dist/standalone-web.js",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "claude",
    "team-memory",
    "ai-agents"
  ],
  "author": "Moorinet Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.21.0",
    "proper-lockfile": "^4.1.2",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "cpy-cli": "^6.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
